<Project Sdk="Microsoft.NET.Sdk">

  <!-- RE reconnaissance only. Not shipped, not in the solution, no
       analyzers (throwaway tooling — same posture as build/TileIcon).
       Drives the real WiseOwl.Casc.Diablo4 library against the live
       install so the FR-C7 layout RE uses our own decoder, not the
       consumer's tools (e:\Paragon stays read-only). -->
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <IsPackable>false</IsPackable>
    <EnableNETAnalyzers>false</EnableNETAnalyzers>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="../../src/WiseOwl.Casc.Diablo4/WiseOwl.Casc.Diablo4.csproj" />
  </ItemGroup>

</Project>
