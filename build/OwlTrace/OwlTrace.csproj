<Project Sdk="Microsoft.NET.Sdk">

  <!--
    One-shot: trace the owner's hand-drawn Wise Owl card photo
    (assets/Owl.jpg) to a clean calligraphic SVG. NOT in the solution,
    NOT packed. The owl SVG it emits is then the source for the icon
    ladder (scripts/gen-icons). The big source photo is read only by this
    tool; it never enters the assistant context.
  -->
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <IsPackable>false</IsPackable>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
    <!-- Throwaway build tool: no analyzers / warnings-as-errors. -->
    <EnableNETAnalyzers>false</EnableNETAnalyzers>
    <RunAnalyzers>false</RunAnalyzers>
    <AnalysisLevel>none</AnalysisLevel>
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="SkiaSharp" Version="2.88.8" />
    <PackageReference Include="BitmapToVector" Version="1.0.0" />
    <PackageReference Include="BitmapToVector.SkiaSharp" Version="1.0.0" />
  </ItemGroup>

</Project>
