<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Build-time icon rasteriser (NOT in WiseOwl.Casc.slnx, NOT packed).
    Renders assets/icons/*.svg to the committed PNG size ladder via
    Svg.Skia. Run through scripts/gen-icons.{sh,ps1}. The SVGs are the
    source of truth; the PNGs are generated artefacts.
  -->
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <IsPackable>false</IsPackable>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Svg.Skia" Version="2.0.0.4" />
  </ItemGroup>

</Project>
