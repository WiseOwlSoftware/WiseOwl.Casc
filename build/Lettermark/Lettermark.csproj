<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Composes the WiseOwl.Casc "CASC" lettermark SVG: real bold-typeface
    glyph outlines (baked to vector path data → no runtime font
    dependency), 2×2 on the shared Wise Owl tile, autumn-brown ink, owl
    brand tick, family keyline. NOT in the solution, NOT packed. Run via
    scripts/gen-icons; the emitted SVG feeds the PNG ladder (IconGen).
  -->
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>disable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <IsPackable>false</IsPackable>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
    <EnableNETAnalyzers>false</EnableNETAnalyzers>
    <RunAnalyzers>false</RunAnalyzers>
    <AnalysisLevel>none</AnalysisLevel>
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="SkiaSharp" Version="2.88.8" />
  </ItemGroup>

</Project>
